{{!
    @template mod_bigbluebuttonbn/unconfigured_view

    Neutral state page shown when the BigBlueButton server is not yet configured.

    Example context (json):
    {
        "heading": "BigBlueButton is not yet configured",
        "message": "The BigBlueButton server is not yet configured.",
        "settingsurl": "/admin/settings.php?section=modsettingbigbluebuttonbn",
        "settingslinktext": "BigBlueButton settings"
    }
}}
<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col col-sm-8 col-md-6">
            <div class="card">
                <div class="card-body text-center p-5">
                    <h4 class="card-title mb-3">{{heading}}</h4>
                    <p class="card-text">{{message}}</p>
                    {{#settingsurl}}
                    <a href="{{settingsurl}}" class="btn btn-primary mt-2">{{settingslinktext}}</a>
                    {{/settingsurl}}
                </div>
            </div>
        </div>
    </div>
</div>
